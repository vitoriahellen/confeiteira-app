# Banco de dados (Neon / Vercel Postgres) — preenchido automaticamente
# quando você adiciona a integração "Postgres" no projeto na Vercel.
DATABASE_URL=

# Segredo usado para assinar os cookies de sessão. Gere um valor aleatório forte.
AUTH_SECRET=

# Superchat (WhatsApp) — gere em app.superchat.com > Configurações > API
SUPERCHAT_API_KEY=

# Opcional: ID do canal de WhatsApp na Superchat. Se não definido, o sistema
# descobre automaticamente o primeiro canal do tipo WhatsApp da conta.
SUPERCHAT_CHANNEL_ID=

# Número (com DDI+DDD, só dígitos) para receber os alertas internos de entrega
SUPERCHAT_NUMERO_INTERNO=

# Segredo para proteger as rotas de cron contra chamadas externas
CRON_SECRET=
