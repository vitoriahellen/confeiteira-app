# Banco de dados (Neon / Vercel Postgres) — preenchido automaticamente
# quando você adiciona a integração "Postgres" no projeto na Vercel.
DATABASE_URL=

# Segredo usado para assinar os cookies de sessão. Gere um valor aleatório forte.
AUTH_SECRET=

# A integração de mensageria (Z-API) agora é configurada direto no app, em
# Configurações → Parâmetros — os tokens ficam salvos criptografados no banco
# (chave derivada de AUTH_SECRET). As variáveis abaixo são só um FALLBACK
# legado: continuam funcionando se já estiverem definidas, mas não é mais
# necessário usá-las.
# ZAPI_INSTANCE_ID=
# ZAPI_TOKEN=
# ZAPI_CLIENT_TOKEN=
# ZAPI_NUMERO_INTERNO=

# Segredo para proteger as rotas de cron contra chamadas externas
CRON_SECRET=
